{
  "name": "api2api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n worker,web -c blue,magenta \"wrangler dev\" \"cd frontend && npm run dev\"",
    "dev:worker": "wrangler dev",
    "build:frontend": "cd frontend && npm run build",
    "deploy": "npm run build:frontend && wrangler deploy",
    "typecheck": "tsc --noEmit && cd frontend && npm run typecheck",
    "db:migrate:local": "wrangler d1 migrations apply api2api-db --local",
    "db:migrate": "wrangler d1 migrations apply api2api-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
